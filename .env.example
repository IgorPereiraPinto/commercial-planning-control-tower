# =============================================================================
# .env.example — Template de variáveis de ambiente
# Commercial Planning Control Tower
# =============================================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores reais no arquivo .env
#   3. NUNCA commite o arquivo .env no Git (já está no .gitignore)
#
# [REUTILIZAÇÃO]: Para novos projetos, ajuste apenas os valores abaixo.
#   A estrutura do código permanece a mesma.
# =============================================================================

# --- Caminhos das fontes de dados (Excel) ------------------------------------
# Caminho absoluto ou relativo à raiz do projeto
# [REUTILIZAÇÃO]: Substitua pelos caminhos das novas fontes

DATA_PATH_DIMENSOES=Dimensões/Dimensões.xlsx
DATA_PATH_VENDAS=Extrações/Vendas.xlsx
DATA_PATH_METAS_DIR=Metas/

# Anos disponíveis nos arquivos de meta (separados por vírgula)
# [REUTILIZAÇÃO]: Ajuste os anos disponíveis no novo projeto
METAS_ANOS=2018,2019,2020,2021

# --- Conexão SQL Server -------------------------------------------------------
# Formato com autenticação Windows (mais comum em ambientes corporativos):
#   DB_SERVER=SEU_SERVIDOR\INSTANCIA
#   DB_DATABASE=nome_do_banco
#   DB_TRUSTED_CONNECTION=yes
#
# Formato com usuário e senha (ambientes cloud ou fora do domínio):
#   DB_USER=seu_usuario
#   DB_PASSWORD=sua_senha

DB_SERVER=localhost\SQLEXPRESS
DB_DATABASE=planejamento_comercial
DB_TRUSTED_CONNECTION=yes
# DB_USER=
# DB_PASSWORD=

# Driver ODBC instalado no sistema
# Verifique qual versão está instalada: Painel de Controle > Fontes de Dados ODBC
# Ou execute no Python: import pyodbc; print(pyodbc.drivers())
DB_DRIVER=ODBC Driver 17 for SQL Server

# --- Schemas SQL Server -------------------------------------------------------
# [REUTILIZAÇÃO]: Altere os nomes dos schemas conforme padrão do novo projeto
DB_SCHEMA_RAW=raw
DB_SCHEMA_STAGING=staging
DB_SCHEMA_DW=dw

# --- Configurações do ETL -----------------------------------------------------
# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Caminho do arquivo de log
LOG_FILE=logs/etl.log

# Comportamento ao carregar: truncate (limpa e recarrega) ou append (adiciona)
# Para projetos com volume pequeno, truncate é mais simples e seguro
LOAD_STRATEGY=truncate
