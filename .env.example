# =============================================================================
# .env.example — Variáveis de ambiente do projeto
# Planejamento Comercial — Planejamento Comercial
# =============================================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores do seu ambiente nos campos marcados com [EDITÁVEL]
#   3. O arquivo .env está no .gitignore — NUNCA o commite
#
# Campos sem [EDITÁVEL] funcionam com o valor padrão para começar.
# =============================================================================

# --- Caminhos das fontes de dados (Excel) ------------------------------------
# [EDITÁVEL] Ajuste se os arquivos estiverem em outra localização relativa à raiz
DATA_PATH_DIMENSOES=data/raw/Dimensoes.xlsx
DATA_PATH_VENDAS=data/raw/Vendas.xlsx
DATA_PATH_METAS_DIR=data/raw/

# [EDITÁVEL] Anos disponíveis nos arquivos de meta (separados por vírgula)
# Adicione ex: 2022,2023 quando houver novos arquivos Meta_XXXX.xlsx
METAS_ANOS=2018,2019,2020,2021

# --- Conexão SQL Server -------------------------------------------------------
# Autenticação Windows (uso corporativo com Active Directory — mais comum):
#   DB_TRUSTED_CONNECTION=yes  → não precisa de usuário/senha no arquivo
#
# Autenticação SQL (Azure SQL, fora do domínio ou cloud):
#   DB_TRUSTED_CONNECTION=no  → preencha DB_USER e DB_PASSWORD abaixo
#
# [EDITÁVEL] Endereço do servidor
#   Local:   localhost\SQLEXPRESS
#   Azure:   seu-servidor.database.windows.net
DB_SERVER=localhost\SQLEXPRESS

# [EDITÁVEL] Nome do banco de dados
DB_DATABASE=planejamento_comercial

# [EDITÁVEL] Tipo de autenticação: yes (Windows) | no (SQL)
DB_TRUSTED_CONNECTION=yes

# [EDITÁVEL] Obrigatório apenas quando DB_TRUSTED_CONNECTION=no
DB_USER=
DB_PASSWORD=

# [EDITÁVEL] Driver ODBC instalado na máquina
# Verifique: Painel de Controle > Ferramentas Administrativas > Fontes de Dados ODBC
# Ou: python -c "import pyodbc; print(pyodbc.drivers())"
# Opções comuns: "ODBC Driver 17 for SQL Server" | "ODBC Driver 18 for SQL Server"
DB_DRIVER=ODBC Driver 17 for SQL Server

# --- Schemas SQL Server -------------------------------------------------------
# [EDITÁVEL] Ajuste os nomes se o padrão do novo projeto for diferente
DB_SCHEMA_RAW=raw
DB_SCHEMA_STAGING=staging
DB_SCHEMA_DW=dw

# --- Configurações do ETL -----------------------------------------------------
# Estratégia de carga: truncate (limpa e recarrega) | append (adiciona)
# truncate é mais seguro para volumes pequenos com Excel como fonte de verdade
LOAD_STRATEGY=truncate

# --- Logs ---------------------------------------------------------------------
# [EDITÁVEL] Use DEBUG para investigar problemas; INFO para uso normal
LOG_LEVEL=INFO

# Caminho do arquivo de log — criado automaticamente se não existir
LOG_FILE=logs/etl.log
