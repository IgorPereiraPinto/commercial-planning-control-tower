# =============================================================================
# .gitignore — Arquivos que NÃO devem ser versionados
# Planejamento Comercial
# =============================================================================

# --- Segurança — NUNCA versionar ---
.env
*.key
*.pem

# --- Ambiente virtual Python ---
.venv/
venv/
env/

# --- Bytecode Python ---
__pycache__/
*.pyc
*.pyo

# --- Logs gerados pelo pipeline ---
logs/
*.log

# --- Arquivos temporários ---
*.tmp
*.bak
.DS_Store
Thumbs.db

# --- IDE ---
.vscode/settings.json
.idea/

# --- pytest e coverage ---
.pytest_cache/
pytest-cache-files-*/
.coverage
htmlcov/

# --- Jupyter Notebooks (checkpoints) ---
.ipynb_checkpoints/

# --- Arquivos de dados sensíveis ---
# Os Excel de origem são mantidos versionados (são as fontes do projeto)
# Remova as linhas abaixo se quiser excluir os Excels do git
# *.xlsx
# *.csv
